# ----------------------------------------------------------------------------
# clearvoiance self-host env template
#
# Copy to `.env` in this directory before running:
#   cp deploy/.env.example deploy/.env
#   docker compose -f deploy/docker-compose.yml up -d
#
# Every variable has a working dev default so `cp + up -d` just works.
# Change the passwords before exposing anything beyond localhost.
# ----------------------------------------------------------------------------

# ---- Core ------------------------------------------------------------------

# Image tag applied to both engine + dashboard builds. Bump to pin a release.
CLEARVOIANCE_VERSION=0.0.0-dev

# Public URL of the engine's HTTP/WS surface. The dashboard bakes this in at
# build time (NEXT_PUBLIC_* → rebuild required to change), so set it before
# the first `docker compose up -d --build ui`.
#   - localhost dev:       http://localhost:9101
#   - Traefik-hosted:      https://api.clearvoiance.example.com
CLEARVOIANCE_API_URL=http://localhost:9101

# External marketing + docs site the dashboard's "Docs" link points at.
# Baked into the UI bundle like the API URL — rebuild `ui` to change.
# Leave the default unless you run a fork with its own docs deploy.
CLEARVOIANCE_DOCS_URL=https://clearvoiance.vercel.app

# ---- Postgres (metadata: sessions, replays, API keys, audit log) ----------

POSTGRES_USER=clearvoiance
POSTGRES_PASSWORD=dev
POSTGRES_DB=clearvoiance
# Host port exposed on 127.0.0.1 (loopback only). Internal container port is
# always 5432.
POSTGRES_HOST_PORT=5499

# ---- ClickHouse (event store + replay results + db observations) ----------

CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=dev
CLICKHOUSE_DB=clearvoiance
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# ---- MinIO / S3 (large request/response body blobs) -----------------------

MINIO_ROOT_USER=dev
MINIO_ROOT_PASSWORD=devdevdev
MINIO_BUCKET=clearvoiance-blobs
MINIO_REGION=us-east-1
# MinIO requires path-style addressing; toggle off if you swap in real S3.
MINIO_PATH_STYLE=true
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9001

# ---- Engine (gRPC capture + HTTP control plane) ---------------------------

# Host ports. Internal container ports are hardcoded to 9100 / 9101.
ENGINE_GRPC_PORT=9100
ENGINE_HTTP_PORT=9101

# ---- Dashboard (Next.js UI) -----------------------------------------------

DASHBOARD_PORT=3000

# ---- DB observer (optional — correlates SUT slow queries to replay events)-
#
# Not started by default. Uncomment the `db-observer` block in
# docker-compose.yml and set these to the Postgres you want to watch. The
# SUT Postgres must be reachable from the compose network.
#
# CLEARVOIANCE_OBSERVER_POSTGRES_DSN=postgres://readonly:pw@sut-postgres:5432/app?sslmode=disable
# CLEARVOIANCE_OBSERVER_CLICKHOUSE_DSN=clickhouse://default:dev@clickhouse:9000/clearvoiance

# ---- Traefik (optional — uncomment labels in docker-compose.yml) ----------
#
# Used only when the `traefik.enable=true` labels in the compose file are
# uncommented. The external network must already exist, or create it with:
#   docker network create traefik_proxy
#
# TRAEFIK_NETWORK=traefik_proxy
# TRAEFIK_ENTRYPOINT=websecure
# TRAEFIK_CERT_RESOLVER=le
# TRAEFIK_API_HOST=api.clearvoiance.example.com
# TRAEFIK_UI_HOST=app.clearvoiance.example.com
