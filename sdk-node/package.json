{
  "name": "@clearvoiance/node",
  "version": "0.1.5",
  "description": "Node.js SDK for clearvoiance — capture traffic from your backend and replay it at N× speed.",
  "license": "Apache-2.0",
  "author": "Davit Tavadze",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/charlses/clearvoiance.git",
    "directory": "sdk-node"
  },
  "homepage": "https://github.com/charlses/clearvoiance/tree/main/sdk-node",
  "bugs": {
    "url": "https://github.com/charlses/clearvoiance/issues"
  },
  "keywords": [
    "clearvoiance",
    "load-testing",
    "stress-testing",
    "traffic-replay",
    "observability"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./http/express": {
      "import": {
        "types": "./dist/adapters/http/express.d.mts",
        "default": "./dist/adapters/http/express.mjs"
      },
      "require": {
        "types": "./dist/adapters/http/express.d.cts",
        "default": "./dist/adapters/http/express.cjs"
      }
    },
    "./http/koa": {
      "import": {
        "types": "./dist/adapters/http/koa.d.mts",
        "default": "./dist/adapters/http/koa.mjs"
      },
      "require": {
        "types": "./dist/adapters/http/koa.d.cts",
        "default": "./dist/adapters/http/koa.cjs"
      }
    },
    "./http/strapi": {
      "import": {
        "types": "./dist/adapters/http/strapi.d.mts",
        "default": "./dist/adapters/http/strapi.mjs"
      },
      "require": {
        "types": "./dist/adapters/http/strapi.d.cts",
        "default": "./dist/adapters/http/strapi.cjs"
      }
    },
    "./socket/socketio": {
      "import": {
        "types": "./dist/adapters/socket/socketio.d.mts",
        "default": "./dist/adapters/socket/socketio.mjs"
      },
      "require": {
        "types": "./dist/adapters/socket/socketio.d.cts",
        "default": "./dist/adapters/socket/socketio.cjs"
      }
    },
    "./cron/node-cron": {
      "import": {
        "types": "./dist/adapters/cron/node-cron.d.mts",
        "default": "./dist/adapters/cron/node-cron.mjs"
      },
      "require": {
        "types": "./dist/adapters/cron/node-cron.d.cts",
        "default": "./dist/adapters/cron/node-cron.cjs"
      }
    },
    "./outbound": {
      "import": {
        "types": "./dist/outbound/index.d.mts",
        "default": "./dist/outbound/index.mjs"
      },
      "require": {
        "types": "./dist/outbound/index.d.cts",
        "default": "./dist/outbound/index.cjs"
      }
    },
    "./hermetic": {
      "import": {
        "types": "./dist/hermetic/index.d.mts",
        "default": "./dist/hermetic/index.mjs"
      },
      "require": {
        "types": "./dist/hermetic/index.d.cts",
        "default": "./dist/hermetic/index.cjs"
      }
    },
    "./db/postgres": {
      "import": {
        "types": "./dist/db/postgres.d.mts",
        "default": "./dist/db/postgres.mjs"
      },
      "require": {
        "types": "./dist/db/postgres.d.cts",
        "default": "./dist/db/postgres.cjs"
      }
    },
    "./db/prisma": {
      "import": {
        "types": "./dist/db/prisma.d.mts",
        "default": "./dist/db/prisma.mjs"
      },
      "require": {
        "types": "./dist/db/prisma.d.cts",
        "default": "./dist/db/prisma.cjs"
      }
    },
    "./http/fastify": {
      "import": {
        "types": "./dist/adapters/http/fastify.d.mts",
        "default": "./dist/adapters/http/fastify.mjs"
      },
      "require": {
        "types": "./dist/adapters/http/fastify.d.cts",
        "default": "./dist/adapters/http/fastify.cjs"
      }
    },
    "./queue/bullmq": {
      "import": {
        "types": "./dist/adapters/queue/bullmq.d.mts",
        "default": "./dist/adapters/queue/bullmq.mjs"
      },
      "require": {
        "types": "./dist/adapters/queue/bullmq.d.cts",
        "default": "./dist/adapters/queue/bullmq.cjs"
      }
    },
    "./auto": {
      "import": {
        "types": "./dist/auto.d.mts",
        "default": "./dist/auto.mjs"
      },
      "require": {
        "types": "./dist/auto.d.cts",
        "default": "./dist/auto.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "pretest": "node scripts/sync-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "sync-version": "node scripts/sync-version.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@prisma/client": "^7.7.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^5.0.6",
    "@types/koa": "^3.0.2",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "bullmq": "^5.74.1",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "koa": "^3.2.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@grpc/grpc-js": "^1.14.3"
  }
}
