{
  "name": "@clearvoiance/node",
  "version": "0.0.0-alpha.0",
  "description": "Node.js SDK for clearvoiance — capture traffic from your backend and replay it at N× speed.",
  "license": "Apache-2.0",
  "author": "Davit Tavadze",
  "repository": {
    "type": "git",
    "url": "https://github.com/charlses/clearvoiance.git",
    "directory": "sdk-node"
  },
  "homepage": "https://github.com/charlses/clearvoiance/tree/main/sdk-node",
  "bugs": {
    "url": "https://github.com/charlses/clearvoiance/issues"
  },
  "keywords": [
    "clearvoiance",
    "load-testing",
    "stress-testing",
    "traffic-replay",
    "observability"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./http/express": {
      "types": "./dist/adapters/http/express.d.ts",
      "import": "./dist/adapters/http/express.js",
      "require": "./dist/adapters/http/express.cjs"
    },
    "./http/koa": {
      "types": "./dist/adapters/http/koa.d.ts",
      "import": "./dist/adapters/http/koa.js",
      "require": "./dist/adapters/http/koa.cjs"
    },
    "./http/strapi": {
      "types": "./dist/adapters/http/strapi.d.ts",
      "import": "./dist/adapters/http/strapi.js",
      "require": "./dist/adapters/http/strapi.cjs"
    },
    "./socket/socketio": {
      "types": "./dist/adapters/socket/socketio.d.ts",
      "import": "./dist/adapters/socket/socketio.js",
      "require": "./dist/adapters/socket/socketio.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/koa": "^3.0.2",
    "@types/node": "^25.6.0",
    "express": "^5.2.1",
    "koa": "^3.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@grpc/grpc-js": "^1.14.3"
  },
  "peerDependencies": {
    "express": ">=4.0.0 <6.0.0",
    "koa": ">=2.0.0 <4.0.0",
    "socket.io": ">=4.0.0 <5.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "koa": { "optional": true },
    "socket.io": { "optional": true }
  }
}
